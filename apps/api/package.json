{
  "name": "@agentclip/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "secret:set": "wrangler secret put GOOGLE_CLIENT_ID --env production && wrangler secret put GOOGLE_CLIENT_SECRET --env production && wrangler secret put SESSION_SECRET --env production",
    "db:init": "wrangler d1 execute agentclip --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute agentclip --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclip/shared": "workspace:*",
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241004.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "wrangler": "^3.80.0"
  }
}
