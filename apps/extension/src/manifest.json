{
  "manifest_version": 3,
  "name": "AgentClip",
  "version": "0.1.0",
  "description": "Save selected text to your AgentClip store, with a confirm/edit step.",
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["https://agentclip.0xkaz.com/*", "http://localhost:8787/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AgentClip",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html"
}
